# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# API
VITE_API_URL=http://localhost:4000/api/v1

# Paymob: per-tenant iframe IDs come from the API (tenant settings), not from the client.
# Base URL for hosted payment iframe (no trailing slash). Override if Paymob changes domains.
# VITE_PAYMOB_IFRAME_BASE_URL=https://accept.paymob.com/api/acceptance/iframes

# Browse map uses OpenFreeMap (MapLibre) — no client token required.
# Server geocoding may still use MAPBOX_TOKEN — see server/.env.example.

# Tenant host emulation (local dev only).
# By default localhost shows the Aqarify marketing site.
# To emulate a tenant portal on localhost:
#   - visit http://localhost:3000/?tenant=<slug>
#   - or http://localhost:3000/t/<slug>
#   - or set BOTH of these:
# VITE_FORCE_TENANT=1
# VITE_DEFAULT_TENANT=kdevelopments

# Site mode: marketing | tenant | auto (default). Overrides hostname heuristics when not "auto".
# VITE_SITE_MODE=marketing
# VITE_SITE_MODE=tenant
