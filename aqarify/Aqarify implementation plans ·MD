## PLAN 13 — Add Supabase Realtime Notification Bell
**Severity:** 🟡 Medium | **Owner:** Frontend | **Est:** 3h

### Problem
Notifications are inserted to DB by cron/service, but users only see them if they visit the notifications page. The topbar bell already polls every 60s — upgrade it to Realtime.

### Files to change
1. `client/src/lib/supabase.ts` — ensure Realtime channel config
2. `client/src/components/shared/topbar.tsx` — add Realtime subscription

### Step 1 — Create useNotificationBell hook
**New file:** `client/src/features/notifications/hooks/use-notification-bell.ts`

```typescript
import { useEffect, useCallback } from "react";
import { useQuery, useQueryClient } from "@tanstack/react-query";
import { api } from "@/lib/api";
import { supabase } from "@/lib/supabase";
import { useAuthStore } from "@/stores/auth.store";

export function useNotificationBell() {
  const qc = useQueryClient();
  const userId = useAuthStore((s) => s.user?.id);

  const { data } = useQuery({
    queryKey: ["unread-notifications"],
    queryFn: async () => {
      const r = await api.get("/notifications/unread-count");
      return r.data.data as { count: number };
    },
    refetchInterval: 60_000,
    enabled: !!userId,
  });

  const invalidate = useCallback(() => {
    qc.invalidateQueries({ queryKey: ["unread-notifications"] });
    qc.invalidateQueries({ queryKey: ["notifications"] });
  }, [qc]);

  // Realtime subscription: re-query whenever a new notification is inserted
  useEffect(() => {
    if (!userId) return;

    const channel = supabase
      .channel(`notifications:user:${userId}`)
      .on(
        "postgres_changes",
        {
          event: "INSERT",
          schema: "public",
          table: "notifications",
          filter: `user_id=eq.${userId}`,
        },
        () => { invalidate(); }
      )
      .subscribe();

    return () => { supabase.removeChannel(channel); };
  }, [userId, invalidate]);

  return { count: data?.count ?? 0 };
}
```

### Step 2 — Update Topbar to use hook
**File:** `client/src/components/shared/topbar.tsx`

```typescript
