# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# API
VITE_API_URL=http://localhost:4000/api/v1

# Maps
VITE_MAPBOX_TOKEN=pk.your-mapbox-token

# Tenant host emulation (local dev only).
# By default localhost shows the Aqarify marketing site.
# To emulate a tenant portal on localhost:
#   - visit http://localhost:3000/?tenant=<slug>
#   - or http://localhost:3000/t/<slug>
#   - or set BOTH of these:
# VITE_FORCE_TENANT=1
# VITE_DEFAULT_TENANT=kdevelopments
