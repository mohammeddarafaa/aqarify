# Server
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Client
CLIENT_URL=http://localhost:3000
# CORS: comma-separated browser origins (defaults to CLIENT_URL when unset).
# ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com
# Apex domain for tenant subdomains (e.g. tenant.example.com when ROOT_DOMAIN=example.com).
# ROOT_DOMAIN=example.com

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Paymob (shared base URL for both per-tenant and platform accounts)
PAYMOB_BASE_URL=https://accept.paymob.com/api

# Aqarify master Paymob account — used for SaaS subscription payments
# (DISTINCT from per-tenant Paymob creds used for customer reservations)
AQARIFY_PAYMOB_API_KEY=
AQARIFY_PAYMOB_INTEGRATION_ID=
AQARIFY_PAYMOB_HMAC_SECRET=
AQARIFY_PAYMOB_IFRAME_ID=
AQARIFY_APP_URL=http://localhost:3000

# Optional: full URL template for redirect after platform (SaaS) card checkout.
# Use {subscription_id} as placeholder. If unset, defaults to
# {AQARIFY_APP_URL}/signup/complete?subscription_id=...
# AQARIFY_PAYMOB_REDIRECT_URL=https://app.example.com/signup/complete?subscription_id={subscription_id}

# Dev-only: when true (or when NODE_ENV!=production AND the three Aqarify
# Paymob vars above are blank), /signup auto-activates the tenant instead
# of generating a Paymob iframe. Exercises the full SaaS flow locally
# without a live Paymob account. NEVER set to true in production.
AQARIFY_DEV_BYPASS_PAYMENT=false

# Resend (Email)
RESEND_API_KEY=re_your-api-key
RESEND_FROM_EMAIL=noreply@aqarify.com

# Releans (SMS — Egypt)
RELEANS_API_KEY=your-releans-api-key
RELEANS_SENDER=Aqarify

# Gulf / fallback SMS (optional — see notification.service routing by tenant.country_code)
UNIFONIC_API_KEY=
INFOBIP_API_KEY=

# Encryption for tenant Paymob secrets (AES-256-CBC). Each segment MUST be 32 characters.
# Single key (legacy):
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
# Or versioned rotation: ENCRYPTION_KEYS=v1:old-32-char-key-here,v2:new-32-char-key-here
# ENCRYPTION_KEYS=v1:0123456789abcdef0123456789abcdef

# Mapbox (server-side geocoding)
MAPBOX_TOKEN=sk.your-mapbox-secret-token
