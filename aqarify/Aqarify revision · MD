### AW1 — Currency hardcoded to EGP everywhere

**Files:** `client/src/lib/format.ts`, `client/src/components/shared/currency-display.tsx`, `server/src/services/paymob.service.ts`

The Arab World uses: EGP, SAR, AED, KWD (3 decimal places), QAR, BHD (3 decimal places), JOD, MAD, LYD, TND, DZD.

```sql
-- ✅ New migration:
ALTER TABLE tenants
  ADD COLUMN IF NOT EXISTS currency        TEXT NOT NULL DEFAULT 'EGP',
  ADD COLUMN IF NOT EXISTS currency_symbol TEXT NOT NULL DEFAULT 'ج.م';
```

```ts
// ✅ client/src/lib/format.ts
const LOCALE_MAP: Record<string, string> = {
  EGP:"ar-EG", SAR:"ar-SA", AED:"ar-AE", KWD:"ar-KW",
  QAR:"ar-QA", BHD:"ar-BH", JOD:"ar-JO", MAD:"ar-MA",
};
const THREE_DECIMAL = new Set(["KWD","BHD","OMR"]);

export function formatCurrency(amount: number, currency = "EGP"): string {
  return new Intl.NumberFormat(LOCALE_MAP[currency] ?? "ar-EG", {
    style: "currency", currency,
    maximumFractionDigits: THREE_DECIMAL.has(currency) ? 3 : 2,
  }).format(amount);
}

// ✅ Paymob service — use tenant currency, not hardcoded "EGP":
currency: params.currency,
```

