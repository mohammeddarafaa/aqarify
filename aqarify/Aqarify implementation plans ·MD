```sql
-- Create the documents storage bucket for receipts and customer uploads.
-- Safe to run multiple times (insert on conflict do nothing).

INSERT INTO storage.buckets (id, name, public, file_size_limit, allowed_mime_types)
VALUES (
  'documents',
  'documents',
  false,  -- private bucket; use signed URLs
  10485760, -- 10 MB
  ARRAY['application/pdf', 'image/jpeg', 'image/png', 'image/webp']
)
ON CONFLICT (id) DO NOTHING;

-- Tenants can read documents within their tenant folder.
-- Service role bypasses RLS so server-side uploads always work.
CREATE POLICY IF NOT EXISTS "documents_tenant_read" ON storage.objects
  FOR SELECT TO authenticated
  USING (
    bucket_id = 'documents'
    AND (storage.foldername(name))[1] = (
      SELECT tenant_id::text FROM public.users WHERE id = auth.uid() LIMIT 1
    )
  );

-- Authenticated users can upload to their own tenant/reservation paths.
CREATE POLICY IF NOT EXISTS "documents_tenant_upload" ON storage.objects
  FOR INSERT TO authenticated
  WITH CHECK (
    bucket_id = 'documents'
    AND (storage.foldername(name))[1] = (
      SELECT tenant_id::text FROM public.users WHERE id = auth.uid() LIMIT 1
    )
  );
```

